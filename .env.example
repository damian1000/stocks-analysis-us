# Copy to .env (or export these) before running.
# .env is .gitignored.

# --- Database (the docker-compose postgres uses these defaults) ---
DB_URL=jdbc:postgresql://localhost:5432/trading
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- FX provider (Frankfurter is keyless and free; rates are quoted against EUR) ---
FX_PROVIDER_URL=https://api.frankfurter.dev/v2/rates

# --- Optional email export ---
# Leave disabled unless SMTP credentials are configured.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=
EMAIL_TO=
EMAIL_TO_NAME=

# --- Optional ---
SERVER_PORT=9000
SPRING_PROFILES_ACTIVE=dev
